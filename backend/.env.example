NODE_ENV=development
PORT=3000
LOG_LEVEL=info
MAX_DIRECTORY_SIZE_BYTES=1099511627776
# Especificar diretórios permitidos (separados por vírgula)
# Exemplo: /home/user/projects,/var/www
# OBRIGATÓRIO em produção!
ALLOWED_PATHS=/home/user/documents,/var/www

# Whitelist de origens CORS permitidas (separadas por vírgula)
# RECOMENDADO configurar em produção
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# API Key para autenticação
# CRÍTICO em produção! Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NÃO usar o valor padrão abaixo em produção
API_KEY=<GERAR_COM_COMANDO_ACIMA_NAO_USE_ESSE_VALOR>
